{
  "manifest_version": 3,
  "name": "KinoHub Search Helper",
  "version": "1.2",
  "description": "Добавляет кнопку Смотреть на KinoHub.",
  "permissions": [],
  "content_scripts": [
    {
      "matches": [
        "*://*.imdb.com/*",
        "*://*.kinopoisk.ru/*",
        "*://*.rottentomatoes.com/*",
        "*://*.metacritic.com/*",
        "*://*.myanimelist.net/*",
        "*://*.shikimori.one/*",
        "*://*.shikimori.me/*"
      ],
      "js": ["content.js"],
      "css": ["style.css"],
      "run_at": "document_start"
    }
  ]
}
